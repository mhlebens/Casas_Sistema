@model IEnumerable<CasoEstudio2.Models.CasasModel>

@{
    ViewData["Title"] = "Consulta de Casas";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">

            <h2 class="text-center mb-4">Consulta de Casas</h2>

            @if (Model != null && Model.Any())
            {
                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Descripción</th>
                            <th>Precio</th>
                            <th>Usuario</th>
                            <th>Estado</th>
                            <th>Fecha</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.DescripcionCasa</td>
                                <td>@item.PrecioCasa.ToString("N2")</td>

                                @if (string.IsNullOrEmpty(item.UsuarioAlquiler))
                                {
                                    <td>-</td>
                                    <td>Disponible</td>
                                }
                                else
                                {
                                    <td>@item.UsuarioAlquiler</td>
                                    <td>Reservada</td>
                                }

                                @if (item.FechaAlquiler == DateTime.MinValue)
                                {
                                    <td>-</td>
                                }
                                else
                                {
                                    <td>@item.FechaAlquiler.ToString("dd/MM/yyyy")</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-warning text-center">
                    No hay casas para mostrar.
                </div>
            }

        </div>
    </div>
</div>