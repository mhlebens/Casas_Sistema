@model CasasModel

@{
    ViewData["Title"] = "Alquiler de Casas";
}

<div class="page-heading">
    <h2>Alquiler de casas</h2>
    <p>Seleccione una casa disponible e ingrese el usuario que realizará el alquiler.</p>
</div>

<section class="card-ui form-card">
    <form asp-controller="Casas" asp-action="Alquilar" method="post">
        <div class="mb-3">
            <label for="IdCasa" class="form-label">Casa disponible</label>
            <select id="IdCasa" name="IdCasa" class="form-select">
                <option value="">-- Seleccione una casa --</option>
                @foreach (var item in ViewBag.Casas)
                {
                    <option value="@item.Value">@item.Text</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label for="PrecioCasa" class="form-label">Precio mensual</label>
            <input id="PrecioCasa" name="PrecioCasa" class="form-control" readonly />
        </div>

        <div class="mb-4">
            <label for="UsuarioAlquiler" class="form-label">Usuario alquiler</label>
            <input id="UsuarioAlquiler" name="UsuarioAlquiler" class="form-control" placeholder="Ingrese el nombre del usuario" />
        </div>

        <button type="submit" class="btn btn-main">Alquilar</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/alquiler.js"></script>
}